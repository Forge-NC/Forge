# Forge Certified Audit — API Endpoint Image (slim)
# For auditing customer API endpoints. No PyTorch/vLLM needed.
# Builds in ~60s, ~200MB final image.

FROM python:3.11-slim

WORKDIR /app

# System deps for cryptography wheel
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libffi-dev && \
    rm -rf /var/lib/apt/lists/*

# Python deps — only what the audit chain actually needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    numpy>=1.24 \
    tiktoken>=0.7

# Copy Forge package (headless subset — no GUI, no audio)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]

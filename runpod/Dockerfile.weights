# Forge Certified Audit — Model Weights Image (fat)
# For auditing customer model weights via local vLLM.
#
# Uses runpod/pytorch base (pre-cached on RunPod workers = instant cold start).
# vLLM installed via pip wheels (no compilation).
# GHA Docker layer caching means the pip install layer only runs once —
# subsequent builds only rebuild the thin forge/ code layer.

FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

WORKDIR /app

# Heavy deps first (cached by Docker layer cache after first build)
# vllm 0.19.0 pins transformers>=4.56,<5 and upgrades torch to 2.10.0.
# System state after this: transformers==4.57.6, huggingface_hub==0.36.2, torch==2.10.0
RUN pip install --no-cache-dir \
    vllm==0.19.0 \
    huggingface_hub

# Lightweight deps the audit chain needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    tiktoken>=0.7

# Use vLLM's pinned transformers (4.57.x) — do NOT force-upgrade to 5.x.
# vLLM 0.19 was tested against transformers 4.x; v5 changed config-loading
# semantics and breaks vLLM's auto_map handling for archs like EXAONE.
#
# Note: EXAONE-3.x has NO in-tree transformers class (HF PR #34652 unmerged
# as of Apr 2026). vLLM has its own native ExaoneForCausalLM and is the
# only viable loader for EXAONE-3.x — that path does not depend on transformers
# version at all. Models marked vllm_only=true in the registry skip the
# transformers fallback entirely (see handler._start_transformers_fallback).
RUN pip install --no-cache-dir accelerate fastapi uvicorn && \
    python -c "\
import transformers, huggingface_hub; \
tv=transformers.__version__; hv=huggingface_hub.__version__; \
print(f'System transformers: {tv}'); print(f'System huggingface_hub: {hv}'); \
assert int(tv.split('.')[0])==4, f'Expected transformers 4.x (vLLM 0.19 pin), got {tv}'; \
print('Versions OK')"

# Copy Forge package (changes frequently — keep last for cache efficiency)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]

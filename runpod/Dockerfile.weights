# Forge Certified Audit — Model Weights Image (fat)
# For auditing customer model weights via local vLLM.
#
# Uses runpod/pytorch base (pre-cached on RunPod workers = instant cold start).
# vLLM installed via pip wheels (no compilation).
# GHA Docker layer caching means the pip install layer only runs once —
# subsequent builds only rebuild the thin forge/ code layer.

FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

WORKDIR /app

# Heavy deps first (cached by Docker layer cache after first build)
RUN pip install --no-cache-dir \
    vllm==0.19.0 \
    huggingface_hub

# Lightweight deps the audit chain needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    tiktoken>=0.7

# Transformers fallback — venv inherits torch/CUDA from system via --system-site-packages,
# but force-reinstalls transformers 5.x into the venv's own site-packages so it shadows
# vLLM's bundled 4.x. --force-reinstall --no-deps ensures pip puts it in the venv even
# though a system version exists, and --no-deps avoids pulling conflicting transitive deps.
RUN python -m venv --system-site-packages /opt/forge-fallback && \
    /opt/forge-fallback/bin/pip install --no-cache-dir \
    --force-reinstall --no-deps "transformers>=5.0" "huggingface_hub>=0.30" && \
    /opt/forge-fallback/bin/pip install --no-cache-dir \
    accelerate fastapi uvicorn && \
    /opt/forge-fallback/bin/python -c "import transformers,sys; v=transformers.__version__; f=transformers.__file__; print(f'Fallback transformers {v} from {f}'); assert int(v.split('.')[0])>=5, f'Expected 5.x got {v}'; assert 'forge-fallback' in f, f'Wrong path: {f}'"

# Copy Forge package (changes frequently — keep last for cache efficiency)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]

# Forge Certified Audit — Model Weights Image (fat)
# For auditing customer model weights via local vLLM.
#
# Uses runpod/pytorch base (pre-cached on RunPod workers = instant cold start).
# vLLM installed via pip wheels (no compilation).
# GHA Docker layer caching means the pip install layer only runs once —
# subsequent builds only rebuild the thin forge/ code layer.

FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

WORKDIR /app

# Heavy deps first (cached by Docker layer cache after first build)
RUN pip install --no-cache-dir \
    vllm==0.19.0 \
    huggingface_hub

# Lightweight deps the audit chain needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    tiktoken>=0.7

# Transformers fallback — fully isolated venv so it doesn't inherit vLLM's old transformers.
# vLLM 0.19 bundles transformers 4.x which can't load exaone or glm4_moe_lite architectures.
# The fallback serves these models via transformers 5.x + FastAPI in a separate process.
# Must NOT use --system-site-packages (system transformers shadows venv's 5.x install).
# Torch is symlinked from system to avoid a 2GB reinstall while keeping import isolation.
RUN python -m venv /opt/forge-fallback && \
    ln -s /usr/local/lib/python3.12/dist-packages/torch /opt/forge-fallback/lib/python3.12/site-packages/torch && \
    ln -s /usr/local/lib/python3.12/dist-packages/torch-*.dist-info /opt/forge-fallback/lib/python3.12/site-packages/ 2>/dev/null; \
    /opt/forge-fallback/bin/pip install --no-cache-dir \
    "transformers>=5.0" \
    accelerate \
    autoawq \
    fastapi \
    uvicorn && \
    /opt/forge-fallback/bin/python -c "import transformers; v=transformers.__version__; print(f'Fallback transformers: {v}'); assert int(v.split(\".\")[0])>=5, f'Expected 5.x, got {v}'"

# Copy Forge package (changes frequently — keep last for cache efficiency)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]

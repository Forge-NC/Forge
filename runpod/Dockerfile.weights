# Forge Certified Audit — Model Weights Image (fat)
# For auditing customer model weights via local vLLM.
#
# Uses runpod/pytorch base (pre-cached on RunPod workers = instant cold start).
# vLLM installed via pip wheels (no compilation).
# GHA Docker layer caching means the pip install layer only runs once —
# subsequent builds only rebuild the thin forge/ code layer.

FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

WORKDIR /app

# Heavy deps first (cached by Docker layer cache after first build)
# vllm 0.19.0 pins transformers>=4.56,<5 and upgrades torch to 2.10.0.
# System state after this: transformers==4.57.6, huggingface_hub==0.36.2, torch==2.10.0
RUN pip install --no-cache-dir \
    vllm==0.19.0 \
    huggingface_hub

# Lightweight deps the audit chain needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    tiktoken>=0.7

# Upgrade system transformers to 5.x so vLLM can load modern architectures
# (exaone, glm4_moe_lite, etc.) that aren't in transformers 4.x.
#
# vLLM 0.19 pins transformers<5 but community confirms it works with 5.x.
# The compressed-tensors package also pins <5, so we force both upgrades.
# Both vLLM's inference engine and the transformers fallback use this.
#
# gptqmodel (required by transformers 5.x for AWQ loading) has no pre-built
# wheels and requires nvidia-smi at build time — installed at runtime on the
# GPU worker. See handler.py _start_transformers_fallback().
#
# Verified: vLLM 0.19 + transformers 5.x works per community (GitHub #34098).
RUN pip install --no-cache-dir --force-reinstall --no-deps \
    "transformers>=5.0,<6.0" \
    "huggingface_hub>=1.5.0,<2.0" && \
    pip install --no-cache-dir accelerate fastapi uvicorn && \
    python -c "\
import transformers, huggingface_hub; \
tv=transformers.__version__; hv=huggingface_hub.__version__; \
print(f'System transformers: {tv}'); print(f'System huggingface_hub: {hv}'); \
assert int(tv.split('.')[0])>=5, f'Expected transformers 5.x, got {tv}'; \
assert int(hv.split('.')[0])>=1, f'Expected huggingface_hub 1.x, got {hv}'; \
print('All assertions passed')"

# Copy Forge package (changes frequently — keep last for cache efficiency)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]

# Forge Certified Audit — Model Weights Image (fat)
# For auditing customer model weights via local vLLM.
#
# Uses runpod/pytorch base (pre-cached on RunPod workers = instant cold start).
# vLLM installed via pip wheels (no compilation).
# GHA Docker layer caching means the pip install layer only runs once —
# subsequent builds only rebuild the thin forge/ code layer.

FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

WORKDIR /app

# Heavy deps first (cached by Docker layer cache after first build)
# vllm 0.19.0 pins transformers>=4.56,<5 and upgrades torch to 2.10.0.
# System state after this: transformers==4.57.6, huggingface_hub==0.36.2, torch==2.10.0
RUN pip install --no-cache-dir \
    vllm==0.19.0 \
    huggingface_hub

# Lightweight deps the audit chain needs
RUN pip install --no-cache-dir \
    runpod \
    requests>=2.28 \
    cryptography>=41.0 \
    tiktoken>=0.7

# Transformers fallback venv — serves models vLLM can't load (exaone, glm4_moe_lite).
#
# Architecture:
#   --system-site-packages inherits torch 2.10.0 + CUDA from system (no reinstall).
#   pip installs transformers 5.x + huggingface_hub 1.x into the VENV's site-packages
#   because the system versions (4.57.6 / 0.36.2) don't satisfy the version constraints.
#   Python's sys.path puts venv before system, so 5.x shadows 4.x automatically.
#   vLLM's Python environment is completely untouched.
#
# gptqmodel (required by transformers 5.x for AWQ) has no pre-built wheels and requires
# nvidia-smi at build time. It MUST be installed at runtime on the GPU worker — this is
# the one unavoidable runtime install. See handler.py _start_transformers_fallback().
#
# Verified dependency chain (2026-04-12):
#   transformers 5.5.3 requires huggingface_hub>=1.5.0,<2.0
#   huggingface_hub 1.2.1+ has is_offline_mode (imported by transformers 5.x)
#   gptqmodel 6.0.3 requires transformers>=5.4.0 (source-only, needs GPU to build)
RUN python -m venv --system-site-packages /opt/forge-fallback && \
    /opt/forge-fallback/bin/pip install --no-cache-dir \
    "transformers>=5.0,<6.0" \
    "huggingface_hub>=1.5.0,<2.0" \
    accelerate \
    fastapi \
    uvicorn && \
    /opt/forge-fallback/bin/python -c "\
import transformers, huggingface_hub; \
tv=transformers.__version__; tf=transformers.__file__; \
hv=huggingface_hub.__version__; hf=huggingface_hub.__file__; \
print(f'transformers {tv} from {tf}'); \
print(f'huggingface_hub {hv} from {hf}'); \
assert int(tv.split('.')[0])>=5, f'transformers: expected 5.x, got {tv}'; \
assert 'forge-fallback' in tf, f'transformers loaded from system, not venv: {tf}'; \
assert int(hv.split('.')[0])>=1, f'huggingface_hub: expected 1.x, got {hv}'; \
assert 'forge-fallback' in hf, f'huggingface_hub loaded from system, not venv: {hf}'; \
print('All assertions passed')"

# Copy Forge package (changes frequently — keep last for cache efficiency)
COPY forge/ /app/forge/
COPY pyproject.toml /app/

# Copy handler
COPY runpod/handler.py /app/handler.py

CMD ["python", "-u", "handler.py"]
